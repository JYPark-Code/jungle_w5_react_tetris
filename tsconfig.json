{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "baseUrl": ".",
    "types": ["vitest/globals"]
  },
  "include": ["src/**/*", "contracts.ts"],
  "exclude": ["node_modules", "dist"]
}
